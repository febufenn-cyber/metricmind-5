# Local bootstrap token only. Production readiness requires this to be absent.
API_TOKEN=replace-me
ENVIRONMENT=development
LOG_LEVEL=silent
API_RATE_LIMIT_PER_MINUTE=120

# Organization and canonical event-table mapping.
ORGANIZATION_ID=demo-org
ORGANIZATION_TIMEZONE=Asia/Kolkata
ANALYTICS_SCHEMA=analytics
ANALYTICS_TABLE=product_events
ANALYTICS_EVENT_NAME_COLUMN=event_name
ANALYTICS_USER_ID_COLUMN=user_id
ANALYTICS_OCCURRED_AT_COLUMN=occurred_at
ANALYTICS_INSERTED_AT_COLUMN=inserted_at
ANALYTICS_STATEMENT_TIMEOUT_MS=15000
ANALYTICS_MAXIMUM_ROWS=1000
ANALYTICS_FRESHNESS_THRESHOLD_MINUTES=360

# Production also requires platform bindings for AUTH_VERIFIER or approved JWT
# verification, membership and durable metadata, HYPERDRIVE/ANALYTICS_DB,
# RATE_LIMITER, and provider notification adapters. Do not place secrets here.

# Hyperdrive local development uses a shell environment variable rather than
# .dev.vars. For the HYPERDRIVE binding, export the local fixture connection
# string documented in README.md.
